# 텍스트 파일은 LF로 통일 (Windows에서 CRLF 자동 변환 방지)
* text=auto eol=lf

# 셸 스크립트는 반드시 LF
*.sh text eol=lf

# YAML/JSON/Terraform
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.tf text eol=lf
*.tfvars text eol=lf

# Python
*.py text eol=lf

# 마크다운/텍스트
*.md text eol=lf
*.txt text eol=lf

# 바이너리는 변환 제외
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pem binary
